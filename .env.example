# ═══════════════════════════════════════════════════════════════════
# BusBook — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to Git.
# ═══════════════════════════════════════════════════════════════════

# ── Flask ───────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars
JWT_SECRET_KEY=change_this_jwt_secret_key_also_32_chars

# ── PayMongo (https://dashboard.paymongo.com/developers) ────────────
# For development: use sk_test_ / pk_test_
# For production:  use sk_live_ / pk_live_
PAYMONGO_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
PAYMONGO_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PUBLIC_KEY
PAYMONGO_WEBHOOK_SECRET=whsk_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── PayPal (https://developer.paypal.com/developer/applications) ────
# For development: sandbox credentials
# For production:  live credentials + change PAYPAL_MODE=live
PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox

# ── Semaphore SMS (https://semaphore.co) — Philippine SMS gateway ───
# ₱0.50 per SMS — used for booking confirmations and OTP
SEMAPHORE_API_KEY=REPLACE_WITH_YOUR_SEMAPHORE_API_KEY

# ── App URL ─────────────────────────────────────────────────────────
# Used for QR code URLs and PayMongo redirect callbacks
# Local development: http://localhost:5000
# Production:        https://yourdomain.com
APP_BASE_URL=http://localhost:5000

# ── Email (Gmail SMTP) ───────────────────────────────────────────────
# For Gmail: enable 2FA → App Passwords → generate 16-char app password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_DEFAULT_SENDER=your_gmail@gmail.com
