# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── Flask secrets (required) ──────────────────────────────────────
SECRET_KEY=your-strong-flask-secret-here
JWT_SECRET_KEY=your-strong-jwt-secret-here
# Access token lifetime in hours (default 8, min 1, max 168)
JWT_ACCESS_HOURS=8

# ── Database (optional — defaults to SQLite) ──────────────────────
DATABASE_URL=sqlite:///bus_ticketing.db

# ── Email / Flask-Mail (optional but recommended) ─────────────────
# Without these, emails are printed to the terminal (console mode).
# With these, real emails are sent via Gmail SMTP.
#
# Gmail setup:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to Google Account → Security → App Passwords
#   3. Generate an App Password for "Mail"
#   4. Paste it below as MAIL_PASSWORD
#
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=yourgmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=yourgmail@gmail.com
